using Gtk 4.0;
using Adw 1;

template $NocturneCarousel: Gtk.Box {
  orientation: vertical;
  spacing: 10;

  Gtk.Button header_button {
    styles [
      "flat",
      "title-2",
      "active_appearance_button"
    ]
    margin-start: 10;
    margin-end: 10;
    halign: start;
    sensitive: false;
    child: Adw.ButtonContent {
      label: _("List");
    };
    tooltip-text: _("List");
    visible: false;
  }

  Gtk.Overlay {
    [overlay]
    Adw.Bin {
      halign: start;
      vexpand: true;
      width-request: 10;
      styles [
        "carousel-overlay-left"
      ]
    }

    [overlay]
    Gtk.Button pan_start_el {
      tooltip-text: _("Pan to the Left");
      icon-name: "pan-start-symbolic";
      valign: end;
      halign: start;
      margin-start: 10;
      margin-bottom: 10;
      visible: false;
      clicked => $pan_start();
      styles [
        "circular",
        "accent"
      ]
    }

    [overlay]
    Adw.Bin {
      halign: end;
      vexpand: true;
      width-request: 10;
      styles [
        "carousel-overlay-right"
      ]
    }

    [overlay]
    Gtk.Button pan_end_el {
      tooltip-text: _("Pan to the Right");
      icon-name: "pan-end-symbolic";
      valign: end;
      halign: end;
      margin-end: 10;
      margin-bottom: 10;
      visible: false;
      clicked => $pan_end();
      styles [
        "circular",
        "accent"
      ]
    }

    child: Adw.Carousel list_el {
      hexpand: true;
      halign: fill;
      spacing: 10;
      allow-long-swipes: true;
      allow-mouse-drag: true;
      allow-scroll-wheel: false;
      page-changed => $page_changed();

      Gtk.EventControllerScroll {
        scroll => $on_scroll();
        flags: both_axes;
      }

      Adw.Spinner {
        height-request: 240;
        width-request: 240;
      }
    };
  }
}